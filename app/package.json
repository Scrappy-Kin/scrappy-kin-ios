{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/require-explicit-build-mode.mjs",
    "build:dev": "VITE_EXECUTION_LANE=dev sh -c 'tsc -b && vite build --mode development'",
    "build:dev:diagnostics": "SCRAPPY_BOOT_DIAGNOSTICS=1 npm run build:dev",
    "build:prod": "VITE_EXECUTION_LANE=production sh -c 'tsc -b && vite build --mode production'",
    "build:qa-storekit": "VITE_EXECUTION_LANE=qa-storekit VITE_APPLE_SUBSCRIPTION_PRODUCT_ID=com.scrappykin.ios.subscription.annual sh -c 'tsc -b && vite build --mode production'",
    "ios:sync:dev": "npm run build:dev && npx cap sync ios",
    "ios:sync:dev:diagnostics": "SCRAPPY_BOOT_DIAGNOSTICS=1 npm run ios:sync:dev",
    "ios:sync:prod": "npm run build:prod && npx cap sync ios",
    "ios:sync:qa-storekit": "npm run build:qa-storekit && npx cap sync ios",
    "ios:copy:qa-storekit": "npm run build:qa-storekit && npx cap copy ios",
    "ios:install:qa-storekit": "node scripts/install-qa-storekit.mjs",
    "ios:install:qa-storekit:device": "node scripts/install-qa-storekit-device.mjs",
    "ios:install:qa-storekit:device:fast": "SCRAPPY_KIN_QA_WEB_ONLY=1 node scripts/install-qa-storekit-device.mjs",
    "ios:fastlane:qa-device": "node scripts/run-fastlane.mjs ios qa_device",
    "ios:fastlane:qa-device-fast": "node scripts/run-fastlane.mjs ios qa_device_fast",
    "ios:fastlane:qa-simulator": "node scripts/run-fastlane.mjs ios qa_simulator",
    "ios:fastlane:prod-archive": "node scripts/fastlane-with-keychain-asc.mjs ios prod_archive",
    "ios:fastlane:prod-testflight": "node scripts/fastlane-with-keychain-asc.mjs ios prod_testflight",
    "ios:fastlane:upload-testflight-ipa": "node scripts/fastlane-with-keychain-asc.mjs ios upload_testflight_ipa",
    "capture:screens": "node scripts/capture-screens.mjs",
    "capture:screens:manual": "node scripts/capture-screens.mjs",
    "qa:agent-browser": "node scripts/preflight-browser-qa.mjs --http-only",
    "qa:web-preflight": "node scripts/preflight-browser-qa.mjs",
    "capture:screens:simulator": "node scripts/capture-simulator-screens.mjs",
    "test": "tsc -p tsconfig.test.json --noEmit && vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:dev": "SCRAPPY_WEB_HARNESS=1 npm run build:dev && vite preview --port 4173",
    "audit:manifest": "node ../scripts/generate-audit-manifest.js",
    "audit:manifest:check": "node ../scripts/generate-audit-manifest.js --check",
    "health-check": "npm run lint && npm audit && npx madge --circular src/ && npx depcheck --ignores=@capacitor/ios",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@ionic/react": "^8.7.16",
    "@ionic/react-router": "^8.7.16",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "history": "^4.10.1",
    "ionicons": "^8.0.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.1",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "madge": "^8.0.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.3"
  }
}
